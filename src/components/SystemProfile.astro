---
---

<section id="profile" class="py-24 px-6 relative">
  <!-- Grid background decoration -->
  <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true" style="
    background-image:
      linear-gradient(var(--cyber-cyan) 1px, transparent 1px),
      linear-gradient(90deg, var(--cyber-cyan) 1px, transparent 1px);
    background-size: 60px 60px;
  "></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Section header -->
    <div class="mb-16 gsap-reveal">
      <p class="section-label mb-2">// SECTION_02</p>
      <h2 class="font-display font-bold text-4xl md:text-5xl text-white">
        SYSTEM <span class="neon-cyan">PROFILE</span>
      </h2>
      <div class="mt-3 h-px w-48" style="background: linear-gradient(90deg, var(--cyber-cyan), transparent);"></div>
    </div>

    <!-- Profile grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- IDENTITY column -->
      <div class="hud-panel hud-corner p-6 gsap-reveal">
        <div class="section-label mb-4">[ IDENTITY ]</div>
        <ul class="space-y-3 font-mono text-sm">
          {[
            { label: 'DESIGNATION', value: 'Echo / Echo009' },
            { label: 'ROLE_01', value: 'AI-Augmented Dev' },
            { label: 'ROLE_02', value: 'Full-Stack Engineer' },
            { label: 'ROLE_03', value: 'OSS Enthusiast' },
            { label: 'STATUS', value: 'ONLINE ●' },
          ].map(({ label, value }) => (
            <li class="flex flex-col gap-1">
              <span class="text-xs opacity-40 tracking-widest">{label}</span>
              <span class="text-white" style={label === 'STATUS' ? 'color: var(--cyber-cyan); text-shadow: var(--glow-cyan);' : ''}>{value}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- AI STACK column -->
      <div class="hud-panel hud-corner p-6 gsap-reveal" style="border-color: var(--cyber-pink); box-shadow: 0 0 20px var(--cyber-dim-pink), inset 0 0 20px rgba(255,0,110,0.02);">
        <div class="section-label mb-4" style="color: var(--cyber-pink);">[ AI_STACK ]</div>
        <ul class="space-y-3 font-mono text-sm">
          {[
            { name: 'Claude Code', level: 95 },
            { name: 'Cursor IDE', level: 90 },
            { name: 'GitHub Copilot', level: 80 },
            { name: 'ChatGPT', level: 85 },
          ].map(({ name, level }) => (
            <li class="space-y-1">
              <div class="flex justify-between text-xs">
                <span class="text-white">{name}</span>
                <span style="color: var(--cyber-pink);">{level}%</span>
              </div>
              <div class="h-1 bg-white/10 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full skill-bar"
                  style={`width: ${level}%; background: linear-gradient(90deg, var(--cyber-pink), var(--cyber-purple)); box-shadow: 0 0 8px var(--cyber-pink);`}
                  data-width={level}
                />
              </div>
            </li>
          ))}
        </ul>

        <!-- AI philosophy tagline -->
        <div class="mt-6 pt-4 border-t border-white/10">
          <p class="text-xs font-mono opacity-60 italic leading-relaxed">
            "AI doesn't replace developers;<br />
            it amplifies their capabilities."
          </p>
        </div>
      </div>

      <!-- CONTACT column -->
      <div class="hud-panel hud-corner p-6 gsap-reveal" style="border-color: var(--cyber-yellow); box-shadow: 0 0 20px rgba(245,255,0,0.1), inset 0 0 20px rgba(245,255,0,0.02);">
        <div class="section-label mb-4" style="color: var(--cyber-yellow);">[ CONTACT ]</div>
        <ul class="space-y-4 font-mono text-sm">
          <li>
            <span class="text-xs opacity-40 tracking-widest block mb-1">GITHUB</span>
            <a
              href="https://github.com/Echo009"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white hover:text-cyber-yellow transition-colors"
              style="--hover-color: var(--cyber-yellow);"
            >
              github.com/Echo009 ↗
            </a>
          </li>
          <li>
            <span class="text-xs opacity-40 tracking-widest block mb-1">EMAIL</span>
            <a
              href="mailto:ech0.extreme@foxmail.com"
              class="text-white hover:text-cyber-yellow transition-colors break-all"
            >
              ech0.extreme@foxmail.com ↗
            </a>
          </li>
        </ul>

        <!-- Uptime indicator -->
        <div class="mt-6 pt-4 border-t border-white/10">
          <div class="flex items-center gap-2">
            <span class="block w-2 h-2 rounded-full" style="background: var(--cyber-yellow); box-shadow: var(--glow-yellow); animation: pulseNeon 2s ease-in-out infinite;"></span>
            <span class="text-xs font-mono opacity-60">SYSTEM UPTIME: ACTIVE</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Reveal section heading
  gsap.fromTo(
    '#profile .gsap-reveal',
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#profile',
        start: 'top 80%',
      },
    },
  );

  // Animate skill bars
  ScrollTrigger.create({
    trigger: '#profile',
    start: 'top 70%',
    onEnter: () => {
      document.querySelectorAll('.skill-bar').forEach((bar) => {
        const el = bar as HTMLElement;
        const targetWidth = el.dataset.width + '%';
        gsap.fromTo(el, { width: '0%' }, { width: targetWidth, duration: 1.2, ease: 'power2.out', delay: 0.5 });
      });
    },
  });
</script>

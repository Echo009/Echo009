---
---

<section id="signal" class="py-32 px-6 relative overflow-hidden">
  <!-- Ambient glow effects -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(circle, rgba(0,255,255,0.06) 0%, transparent 70%); filter: blur(40px);"
  ></div>
  <div
    class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(circle, rgba(255,0,110,0.08) 0%, transparent 70%); filter: blur(40px);"
  ></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Section label -->
    <p class="section-label mb-4 gsap-reveal">// SECTION_06 // FINAL_TRANSMISSION</p>

    <!-- Heading -->
    <h2
      class="font-display font-black text-5xl md:text-7xl lg:text-8xl text-white mb-6 gsap-reveal"
      style="letter-spacing: -0.02em; line-height: 1;"
    >
      SEND A
      <span
        class="block"
        style="
          background: linear-gradient(90deg, var(--cyber-cyan), var(--cyber-pink));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          filter: drop-shadow(0 0 20px rgba(0,255,255,0.4));
        "
      >
        SIGNAL
      </span>
    </h2>

    <!-- Subtitle -->
    <p class="font-mono text-white/50 text-sm md:text-base mb-12 gsap-reveal tracking-widest">
      OPEN TO COLLABORATIONS · OPEN SOURCE · AI PROJECTS
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-5 justify-center mb-16 gsap-reveal">
      <a
        href="mailto:ech0.extreme@foxmail.com"
        id="email-btn"
        class="signal-btn-primary font-mono tracking-widest text-sm px-10 py-4 relative overflow-hidden group"
      >
        <span class="relative z-10">[ EMAIL_TRANSMISSION ]</span>
        <div class="signal-btn-shine"></div>
      </a>

      <a
        href="https://github.com/Echo009"
        target="_blank"
        rel="noopener noreferrer"
        id="github-btn"
        class="signal-btn-secondary font-mono tracking-widest text-sm px-10 py-4 relative overflow-hidden group"
      >
        <span class="relative z-10">[ GITHUB_CONNECT ]</span>
        <div class="signal-btn-shine"></div>
      </a>
    </div>

    <!-- Separator -->
    <div class="flex items-center gap-4 mb-8 gsap-reveal">
      <div class="flex-1 h-px" style="background: linear-gradient(90deg, transparent, var(--cyber-cyan)40);"></div>
      <span class="font-mono text-xs opacity-30">EOF</span>
      <div class="flex-1 h-px" style="background: linear-gradient(90deg, var(--cyber-cyan)40, transparent);"></div>
    </div>

    <!-- Social icons row -->
    <div class="flex justify-center gap-6 gsap-reveal">
      <a
        href="https://github.com/Echo009"
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon-link font-mono text-xs tracking-widest opacity-50 hover:opacity-100 transition-opacity"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color: var(--cyber-cyan); margin: 0 auto 4px;">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GITHUB
      </a>
      <a
        href="mailto:ech0.extreme@foxmail.com"
        class="social-icon-link font-mono text-xs tracking-widest opacity-50 hover:opacity-100 transition-opacity"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--cyber-pink); margin: 0 auto 4px;">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        EMAIL
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-8 px-6 border-t" style="border-color: rgba(0,255,255,0.1);">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="font-mono text-xs opacity-30 tracking-widest">
      © 2024 Echo009 // ALL_SYSTEMS_NOMINAL
    </span>
    <span class="font-mono text-xs opacity-30 tracking-widest">
      BUILT WITH ASTRO + THREE.JS + GSAP
    </span>
    <div class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full" style="background: var(--cyber-cyan); animation: pulseNeon 2s ease-in-out infinite;"></span>
      <span class="font-mono text-xs opacity-30 tracking-widest">ONLINE</span>
    </div>
  </div>
</footer>

<style>
  .signal-btn-primary {
    display: inline-block;
    text-decoration: none;
    border: 1px solid var(--cyber-cyan);
    color: var(--cyber-cyan);
    text-shadow: var(--glow-cyan);
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
    transition: all 0.3s ease;
  }
  .signal-btn-primary:hover {
    background: var(--cyber-cyan);
    color: var(--cyber-black);
    text-shadow: none;
    box-shadow: var(--glow-cyan);
  }

  .signal-btn-secondary {
    display: inline-block;
    text-decoration: none;
    border: 1px solid var(--cyber-pink);
    color: var(--cyber-pink);
    text-shadow: var(--glow-pink);
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
    transition: all 0.3s ease;
  }
  .signal-btn-secondary:hover {
    background: var(--cyber-pink);
    color: white;
    text-shadow: none;
    box-shadow: var(--glow-pink);
  }

  .signal-btn-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255, 255, 255, 0.1) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .signal-btn-primary:hover .signal-btn-shine,
  .signal-btn-secondary:hover .signal-btn-shine {
    transform: translateX(100%);
  }

  .social-icon-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: white;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    '#signal .gsap-reveal',
    { opacity: 0, y: 40 },
    {
      opacity: 1, y: 0, duration: 0.9, stagger: 0.15, ease: 'power3.out',
      scrollTrigger: { trigger: '#signal', start: 'top 80%' },
    },
  );

  // Button hover micro-animation
  ['#email-btn', '#github-btn'].forEach((selector) => {
    const btn = document.querySelector(selector);
    if (!btn) return;
    btn.addEventListener('mouseenter', () => {
      gsap.to(btn, { scale: 1.03, duration: 0.2, ease: 'power1.out' });
    });
    btn.addEventListener('mouseleave', () => {
      gsap.to(btn, { scale: 1, duration: 0.2, ease: 'power1.out' });
    });
  });
</script>

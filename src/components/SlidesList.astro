---
interface SlideMeta {
  title: string;
  date: string;
  description: string;
  cover: string;
  slug: string;
}

interface Props {
  slides: SlideMeta[];
}

const { slides } = Astro.props;
---

<div class="slides-grid">
  {slides.map((slide) => (
    <a href={`/slides/${slide.slug}/index.html`} class="slide-card group">
      <div class="slide-cover">
        {slide.cover ? (
          <img src={slide.cover} alt={slide.title} loading="lazy" />
        ) : (
          <div class="slide-cover-gradient">
            <div class="gradient-inner">
              <span class="gradient-title">{slide.title}</span>
            </div>
          </div>
        )}
      </div>

      <div class="slide-info">
        <h3 class="slide-title">{slide.title}</h3>
        <div class="slide-meta">
          {slide.date && (
            <time class="slide-date">{slide.date}</time>
          )}
        </div>
        {slide.description && (
          <p class="slide-desc">{slide.description}</p>
        )}
      </div>

      <div class="corner-deco top-left"></div>
      <div class="corner-deco top-right"></div>
      <div class="corner-deco bottom-left"></div>
      <div class="corner-deco bottom-right"></div>
    </a>
  ))}
</div>

<style>
  .slides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 2rem;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .slide-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 255, 255, 0.12);
    background: linear-gradient(135deg, rgba(0, 255, 255, 0.02) 0%, rgba(5, 5, 16, 0.95) 100%);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .slide-card:hover {
    border-color: rgba(0, 255, 255, 0.5);
    box-shadow:
      0 0 20px rgba(0, 255, 255, 0.15),
      0 8px 32px rgba(0, 0, 0, 0.4);
    transform: translateY(-3px);
  }

  .slide-cover {
    aspect-ratio: 16 / 9;
    background: var(--cyber-deep, #0a0a1a);
    overflow: hidden;
  }

  .slide-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 0.3s ease, transform 0.4s ease;
  }

  .slide-card:hover .slide-cover img {
    opacity: 1;
    transform: scale(1.02);
  }

  .slide-cover-gradient {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #050510 0%, #0a1628 40%, #0d0a1f 100%);
    position: relative;
    overflow: hidden;
  }

  .slide-cover-gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 30% 40%, rgba(0, 255, 255, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 70% 60%, rgba(123, 47, 255, 0.06) 0%, transparent 70%);
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .slide-card:hover .slide-cover-gradient::before {
    opacity: 1.5;
  }

  .gradient-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 1rem 2rem;
  }

  .gradient-title {
    font-family: 'Orbitron', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(0, 255, 255, 0.5);
    letter-spacing: 0.05em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .slide-info {
    padding: 1.1rem 1.3rem 1.3rem;
  }

  .slide-title {
    font-family: 'Orbitron', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--cyber-cyan, #00ffff);
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.3);
    margin: 0 0 0.6rem;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .slide-meta {
    margin-bottom: 0.5rem;
  }

  .slide-date {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: rgba(224, 224, 224, 0.35);
    letter-spacing: 0.1em;
  }

  .slide-desc {
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
    font-size: 0.82rem;
    color: rgba(224, 224, 224, 0.55);
    line-height: 1.6;
    margin: 0;
  }

  .corner-deco {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: var(--cyber-cyan, #00ffff);
    border-style: solid;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .slide-card:hover .corner-deco {
    opacity: 1;
  }

  .corner-deco.top-left { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .corner-deco.top-right { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .corner-deco.bottom-left { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .corner-deco.bottom-right { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }
</style>

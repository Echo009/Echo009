---
interface SlideMeta {
  title: string;
  date: string;
  description: string;
  cover: string;
  slug: string;
}

interface Props {
  slides: SlideMeta[];
}

const { slides } = Astro.props;
---

<div class="slides-grid">
  {slides.map((slide) => (
    <a href={`/slides/${slide.slug}/`} class="slide-card group">
      <div class="slide-cover">
        {slide.cover ? (
          <img src={slide.cover} alt={slide.title} loading="lazy" />
        ) : (
          <div class="slide-cover-placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <path d="M8 21h8M12 17v4" />
            </svg>
          </div>
        )}
      </div>

      <div class="slide-info">
        <h3 class="slide-title">{slide.title}</h3>
        {slide.date && (
          <time class="slide-date">{slide.date}</time>
        )}
        {slide.description && (
          <p class="slide-desc">{slide.description}</p>
        )}
      </div>

      <div class="corner-deco top-left"></div>
      <div class="corner-deco top-right"></div>
      <div class="corner-deco bottom-left"></div>
      <div class="corner-deco bottom-right"></div>
    </a>
  ))}
</div>

<style>
  .slides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .slide-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 255, 255, 0.15);
    background: linear-gradient(135deg, rgba(0, 255, 255, 0.02) 0%, rgba(5, 5, 16, 0.9) 100%);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .slide-card:hover {
    border-color: var(--cyber-cyan);
    box-shadow: 0 0 20px var(--cyber-dim-cyan);
    transform: translateY(-2px);
  }

  .slide-cover {
    aspect-ratio: 16 / 9;
    background: var(--cyber-deep);
    overflow: hidden;
  }

  .slide-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }

  .slide-card:hover .slide-cover img {
    opacity: 1;
  }

  .slide-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cyber-dim-cyan);
  }

  .slide-info {
    padding: 1rem 1.2rem 1.2rem;
  }

  .slide-title {
    font-family: 'Orbitron', monospace;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--cyber-cyan);
    text-shadow: 0 0 8px #00ffff44;
    margin: 0 0 0.5rem;
  }

  .slide-date {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: #e0e0e055;
    letter-spacing: 0.1em;
  }

  .slide-desc {
    font-size: 0.8rem;
    color: #e0e0e088;
    line-height: 1.5;
    margin: 0.4rem 0 0;
  }

  .corner-deco {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: var(--cyber-cyan);
    border-style: solid;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .slide-card:hover .corner-deco {
    opacity: 1;
  }

  .corner-deco.top-left { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .corner-deco.top-right { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .corner-deco.bottom-left { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .corner-deco.bottom-right { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }
</style>

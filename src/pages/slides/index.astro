---
import Layout from '../../layouts/Layout.astro';
import SlidesList from '../../components/SlidesList.astro';

import fs from 'node:fs';
import path from 'node:path';

interface SlideMeta {
  title: string;
  date: string;
  description: string;
  cover: string;
  slug: string;
}

const slidesDir = path.join(process.cwd(), 'public', 'slides');
const slides: SlideMeta[] = [];

if (fs.existsSync(slidesDir)) {
  const entries = fs.readdirSync(slidesDir, { withFileTypes: true });
  for (const entry of entries) {
    if (!entry.isDirectory()) continue;

    const slug = entry.name;
    const metaPath = path.join(slidesDir, slug, 'meta.json');

    if (fs.existsSync(metaPath)) {
      const meta = JSON.parse(fs.readFileSync(metaPath, 'utf-8'));
      slides.push({
        slug,
        title: meta.title || slug,
        date: meta.date || '',
        description: meta.description || '',
        cover: meta.cover || '',
      });
    } else {
      slides.push({ slug, title: slug, date: '', description: '', cover: '' });
    }
  }

  slides.sort((a, b) => (a.date > b.date ? -1 : a.date < b.date ? 1 : 0));
}
---

<Layout title="Slides // Echo009" description="Echo009 的演示文稿集合">
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-display font-bold text-sm tracking-widest neon-cyan hover:opacity-80 transition-opacity">
      Echo009
    </a>
    <div class="flex items-center gap-8">
      <a href="/" class="font-mono text-xs tracking-widest text-white/50 hover:text-white transition-colors relative nav-link">
        HOME
      </a>
      <a href="/slides" class="font-mono text-xs tracking-widest neon-cyan transition-colors relative nav-link active">
        SLIDES
      </a>
    </div>
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full" style="background: var(--cyber-cyan); animation: pulseNeon 2s ease-in-out infinite;"></span>
      <span class="font-mono text-xs opacity-40 hidden sm:block">SYS::ONLINE</span>
    </div>
  </nav>

  <div id="nav-backdrop" class="fixed top-0 left-0 right-0 h-16 z-40 opacity-100 pointer-events-none" style="
    background: linear-gradient(180deg, rgba(5,5,16,0.9) 0%, transparent 100%);
    backdrop-filter: blur(8px);
  "></div>

  <main class="pt-20 pb-20">
    <section class="slides-hero text-center mb-10 px-6">
      <!-- 背景光晕 -->
      <div class="hero-glow" aria-hidden="true"></div>

      <p class="section-label mb-4">// TRANSMISSIONS //</p>

      <!-- Glitch 标题 -->
      <div class="hero-title-wrapper">
        <!-- 扫描线 -->
        <div class="hero-scanline" aria-hidden="true"></div>

        <h1
          class="glitch-text hero-title"
          data-text="SLIDE DECK"
        >
          SLIDE DECK
        </h1>
      </div>

      <!-- 装饰分隔线 -->
      <div class="hero-divider">
        <div class="hero-divider-sweep" aria-hidden="true"></div>
      </div>

      <p class="font-mono text-white/40 text-sm tracking-widest">
        PRESENTATIONS // TALKS // KNOWLEDGE_SHARES
      </p>
    </section>

    {slides.length > 0 ? (
      <SlidesList slides={slides} />
    ) : (
      <div class="text-center py-20">
        <p class="font-mono text-white/30 text-sm tracking-widest">NO_SIGNAL_DETECTED</p>
        <p class="font-mono text-white/20 text-xs mt-2">暂无幻灯片，敬请期待...</p>
      </div>
    )}
  </main>

  <footer class="py-8 px-6 border-t" style="border-color: rgba(0,255,255,0.1);">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-mono text-xs opacity-30 tracking-widest">
        © 2024-2026 Echo009 // ALL_SYSTEMS_NOMINAL
      </span>
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--cyber-cyan); animation: pulseNeon 2s ease-in-out infinite;"></span>
        <span class="font-mono text-xs opacity-30 tracking-widest">ONLINE</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cyber-cyan);
    box-shadow: var(--glow-cyan);
    transition: width 0.3s ease;
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .nav-link.active {
    color: var(--cyber-cyan) !important;
    text-shadow: var(--glow-cyan);
  }

  /* ── Hero Title Gradient + Glitch ── */
  .hero-title-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(2.8rem, 9vw, 4rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #00ffff, #7b2fff 50%, #ff006e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 24px rgba(0, 255, 255, 0.18)) drop-shadow(0 0 16px rgba(255, 0, 110, 0.12));
    white-space: nowrap;
  }

  /* Glitch 伪元素覆盖渐变色（全局 .glitch-text 默认用纯色） */
  .hero-title.glitch-text::before {
    color: var(--cyber-pink);
    opacity: 0.7;
    clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
  }

  .hero-title.glitch-text::after {
    color: var(--cyber-cyan);
    opacity: 0.7;
    clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%);
  }

  /* ── Scanline ── */
  .hero-scanline {
    position: absolute;
    left: -5%;
    width: 110%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.25), rgba(255, 0, 110, 0.15), transparent);
    animation: heroScan 3s linear infinite;
    pointer-events: none;
    z-index: 3;
  }

  @keyframes heroScan {
    0% { top: -10%; }
    100% { top: 110%; }
  }

  /* ── Divider ── */
  .hero-divider {
    position: relative;
    width: 180px;
    height: 2px;
    margin: 0 auto 0.75rem;
    background: linear-gradient(90deg, rgba(0, 255, 255, 0.15), rgba(255, 0, 110, 0.15));
    border-radius: 1px;
    overflow: hidden;
  }

  .hero-divider-sweep {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.7), rgba(255, 0, 110, 0.5), transparent);
    animation: dividerSweep 2s ease-in-out infinite;
  }

  @keyframes dividerSweep {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* ── Background Glow ── */
  .hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 200px;
    background: radial-gradient(ellipse, rgba(0, 255, 255, 0.04) 0%, rgba(255, 0, 110, 0.03) 40%, transparent 70%);
    pointer-events: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-glow {
      width: 100%;
      opacity: 0.6;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector('.slides-container');
  if (container) {
    const pages = container.querySelectorAll('.slides-page');
    const pagination = container.querySelector('.slides-pagination');
    const pageBtns = container.querySelectorAll('.page-btn');
    const prevBtn = container.querySelector('.page-arrow.prev') as HTMLButtonElement | null;
    const nextBtn = container.querySelector('.page-arrow.next') as HTMLButtonElement | null;
    const pageInfo = container.querySelector('.page-info');
    const totalPages = parseInt(container.getAttribute('data-total-pages') || '1', 10);
    let currentPage = 0;

    function showPage(index: number) {
      if (index < 0 || index >= totalPages || index === currentPage) return;

      const oldPage = pages[currentPage] as HTMLElement;
      const newPage = pages[index] as HTMLElement;

      gsap.to(oldPage, {
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          oldPage.classList.remove('active');
          newPage.classList.add('active');
          gsap.fromTo(newPage, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });

          gsap.fromTo(
            newPage.querySelectorAll('.slide-card'),
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: 'power3.out' },
          );
        },
      });

      currentPage = index;

      pageBtns.forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });

      if (prevBtn) prevBtn.disabled = index === 0;
      if (nextBtn) nextBtn.disabled = index === totalPages - 1;
      if (pageInfo) pageInfo.textContent = `PAGE ${index + 1} / ${totalPages}`;
    }

    pageBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = parseInt(btn.getAttribute('data-page') || '0', 10);
        showPage(target);
      });
    });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => showPage(currentPage - 1));
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => showPage(currentPage + 1));
    }

    gsap.fromTo(
      '.slides-page.active .slide-card',
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: 'power3.out',
        scrollTrigger: { trigger: '.slides-container', start: 'top 80%' },
      },
    );
  }
</script>

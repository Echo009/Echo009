---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Echo009 // AI-Augmented Developer',
  description = 'Full-Stack Engineer. AI Enthusiast. Building the future with Claude Code & Cursor.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Orbitron + Share Tech Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>

  <body class="bg-cyber-black text-white overflow-x-hidden">
    <!-- Scanline overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <!-- Page content -->
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --cyber-black: #050510;
    --cyber-deep: #0a0a1a;
    --cyber-cyan: #00ffff;
    --cyber-pink: #ff006e;
    --cyber-yellow: #f5ff00;
    --cyber-purple: #7b2fff;
    --cyber-dim-cyan: #00ffff33;
    --cyber-dim-pink: #ff006e33;

    --glow-cyan: 0 0 10px #00ffff, 0 0 30px #00ffff66, 0 0 60px #00ffff33;
    --glow-pink: 0 0 10px #ff006e, 0 0 30px #ff006e66, 0 0 60px #ff006e33;
    --glow-yellow: 0 0 10px #f5ff00, 0 0 30px #f5ff0066, 0 0 60px #f5ff0033;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: 'Share Tech Mono', monospace;
    background-color: var(--cyber-black);
  }

  body {
    position: relative;
    min-height: 100vh;
  }

  /* Scanlines overlay */
  .scanlines {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.08) 2px,
      rgba(0, 0, 0, 0.08) 4px
    );
  }

  /* Selection color */
  ::selection {
    background: var(--cyber-cyan);
    color: var(--cyber-black);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-track {
    background: var(--cyber-black);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--cyber-cyan);
    box-shadow: var(--glow-cyan);
  }

  /* Neon text utilities */
  .neon-cyan {
    color: var(--cyber-cyan);
    text-shadow: var(--glow-cyan);
  }
  .neon-pink {
    color: var(--cyber-pink);
    text-shadow: var(--glow-pink);
  }
  .neon-yellow {
    color: var(--cyber-yellow);
    text-shadow: var(--glow-yellow);
  }

  /* Section heading pattern */
  .section-label {
    font-family: 'Orbitron', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--cyber-cyan);
    opacity: 0.7;
  }

  /* HUD panel */
  .hud-panel {
    border: 1px solid var(--cyber-cyan);
    background: linear-gradient(
      135deg,
      rgba(0, 255, 255, 0.03) 0%,
      rgba(0, 10, 30, 0.8) 100%
    );
    box-shadow: 0 0 20px var(--cyber-dim-cyan), inset 0 0 20px rgba(0, 255, 255, 0.02);
    position: relative;
  }
  .hud-panel::before {
    content: '';
    position: absolute;
    inset: -1px;
    background: linear-gradient(90deg, var(--cyber-cyan), var(--cyber-pink), var(--cyber-cyan));
    background-size: 200% 100%;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .hud-panel:hover::before {
    opacity: 0.4;
    animation: borderFlow 2s linear infinite;
  }

  /* Corner decorations for HUD panels */
  .hud-corner::before,
  .hud-corner::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--cyber-cyan);
    border-style: solid;
  }
  .hud-corner::before {
    top: -1px;
    left: -1px;
    border-width: 2px 0 0 2px;
  }
  .hud-corner::after {
    bottom: -1px;
    right: -1px;
    border-width: 0 2px 2px 0;
  }

  /* Glitch text */
  .glitch-text {
    position: relative;
    animation: glitchMain 4s infinite;
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    opacity: 0.8;
  }
  .glitch-text::before {
    color: var(--cyber-pink);
    animation: glitchBefore 4s infinite;
    clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
  }
  .glitch-text::after {
    color: var(--cyber-cyan);
    animation: glitchAfter 4s infinite;
    clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%);
  }

  @keyframes glitchMain {
    0%, 89%, 100% { transform: translate(0); }
    90% { transform: translate(-2px, 1px); }
    91% { transform: translate(2px, -1px); }
    92% { transform: translate(0); }
    95% { transform: translate(-1px, 2px); }
    96% { transform: translate(1px, -2px); }
    97% { transform: translate(0); }
  }
  @keyframes glitchBefore {
    0%, 89%, 100% { transform: translate(0); }
    90% { transform: translate(3px, 0); }
    91% { transform: translate(-3px, 0); }
    92% { transform: translate(0); }
  }
  @keyframes glitchAfter {
    0%, 89%, 100% { transform: translate(0); }
    90% { transform: translate(-3px, 0); }
    91% { transform: translate(3px, 0); }
    92% { transform: translate(0); }
  }

  @keyframes borderFlow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  @keyframes pulseNeon {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .cursor-blink {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--cyber-cyan);
    margin-left: 4px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
    box-shadow: var(--glow-cyan);
  }

  /* GSAP initial hidden state */
  .gsap-reveal {
    opacity: 0;
    transform: translateY(30px);
  }
</style>
